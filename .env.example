# GERÇEK ANAHTARLARI BU DOSYAYA YAZMAYIN.

# Google Cloud Chirp 3 HD
GOOGLE_CLOUD_PROJECT=turkce-eser-tts-lab-2026
URETIM_GOOGLE_TTS_VOICE=tr-TR-Chirp3-HD-Kore
GOOGLE_TTS_LANGUAGE=tr-TR

# Üretim güvenliği
URETIM_BULUT_KARAKTER_LIMITI=100000

# İsteğe bağlı klasör geçersiz kılmaları
ESER_GELEN_KLASORU=C:\\Users\\Lenovo\\Desktop\\gelen-eser
ESER_ARSIVI=C:\\Users\\Lenovo\\Desktop\\arsiv
ESER_METIN_ARSIVI=C:\\Users\\Lenovo\\Desktop\\metin-arsivi
ESER_SES_ARSIVI=C:\\Users\\Lenovo\\Desktop\\ses-arsivi
ESER_URETIM_KUYRUGU=C:\\Users\\Lenovo\\Desktop\\eser-otomasyon-kuyruk
ESER_KATALOGU=C:\\Users\\Lenovo\\Desktop\\eser-katalogu.xlsx
MAVEN_CMD=C:\\Tools\\apache-maven-3.9.16\\bin\\mvn.cmd
ESER_MAKSIMUM_INDIRME_MB=700

# Yerel OCR — metadata için ilk sayfalar, yedek metin yoksa tam PDF
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSDATA_PREFIX=C:\\Users\\Lenovo\\AppData\\Local\\EserOtomasyon\\tessdata
ESER_OCR_DPI=220
ESER_OCR_PSM=3
ESER_OCR_MAKSIMUM_SAYFA=600

# Metadata bulut servisleri ZORUNLU DEĞİLDİR.
# Yerel künye motoru önce çalışır; yeterliyse bu servisler çağrılmaz.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Premium TTS — ElevenLabs anahtarı metadata için kullanılmaz.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_NAME=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_ALLOW_OVERAGE=false
ELEVENLABS_MOCK=false

# Yerel Piper TTS
PIPER_PYTHON=C:\\path\\to\\.venv-piper\\Scripts\\python.exe
PIPER_DATA_DIR=C:\\Users\\Lenovo\\Desktop\\piper-voices
PIPER_VOICE=tr_TR-dfki-medium
PIPER_USE_CUDA=false

# FFmpeg
FFMPEG_PATH=C:\\path\\to\\ffmpeg.exe
PIPER_MP3_BITRATE=64k
TTS_LAB_MP3_BITRATE=128k

# Diğer isteğe bağlı ses sağlayıcısı
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
